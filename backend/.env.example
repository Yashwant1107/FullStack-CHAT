# Local development only. Hosts like Render provide PORT automatically.
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=https://your-frontend-domain.com
# Optional: allow multiple frontend origins, comma-separated
# CLIENT_URLS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
